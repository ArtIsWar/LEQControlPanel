# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.cs        text diff=csharp
*.xaml      text
*.csproj    text
*.sln       text eol=crlf
*.props     text
*.targets   text

# Scripts
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Config
*.json      text
*.xml       text
*.config    text
*.yml       text
*.yaml      text
*.md        text
*.txt       text
*.editorconfig text

# Binary
*.ico       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.exe       binary
*.dll       binary
*.pdb       binary
