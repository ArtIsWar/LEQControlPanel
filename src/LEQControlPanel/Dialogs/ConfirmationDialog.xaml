<Window x:Class="LEQControlPanel.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Title="Exit Behavior">

    <Window.Resources>
        <!-- Dialog Button Style -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A0A0A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Behavior Option Button Style -->
        <Style x:Key="BehaviorButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="#151515"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="14,10"
                                Margin="0,3"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Radio circle -->
                                <Border x:Name="radioOuter" Grid.Column="0"
                                        Width="16" Height="16"
                                        Background="#0A0A0A"
                                        BorderBrush="#444444"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        VerticalAlignment="Center">
                                    <Ellipse x:Name="radioDot"
                                             Width="8" Height="8"
                                             Fill="#FFD700"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="radioOuter" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="border" Property="Background" Value="#1F1A0D"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#1F1A0D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FFD700"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox Style -->
        <Style x:Key="RememberCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="checkBorder"
                                    Width="16"
                                    Height="16"
                                    Background="#0A0A0A"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="checkMark"
                                         Text="&#x2713;"
                                         FontSize="12"
                                         FontWeight="Bold"
                                         Foreground="#FFD700"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#101010"
            BorderBrush="{StaticResource Brush_BorderDark}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20"
            MinWidth="380">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="EXIT BEHAVIOR"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#777777"
                       Margin="0,0,0,12"/>

            <!-- Body Message -->
            <TextBlock Grid.Row="1"
                       Text="What should happen when you close the window?"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="{StaticResource Brush_TextWhite}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <!-- Behavior Options -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <RadioButton x:Name="OptionExitApplication"
                             GroupName="CloseBehavior"
                             IsChecked="True"
                             Style="{StaticResource BehaviorButtonStyle}"
                             TabIndex="0">
                    <StackPanel>
                        <TextBlock Text="Exit Application"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush_TextWhite}"/>
                        <TextBlock Text="Close completely and stop all background processing"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="OptionMinimizeToTray"
                             GroupName="CloseBehavior"
                             Style="{StaticResource BehaviorButtonStyle}"
                             TabIndex="1">
                    <StackPanel>
                        <TextBlock Text="Minimize to Tray"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush_TextWhite}"/>
                        <TextBlock Text="Hide window and keep running in the system tray"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- Checkbox -->
            <CheckBox x:Name="RememberChoiceCheckbox"
                      Grid.Row="3"
                      Content="Remember and don't ask again"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      Foreground="#999999"
                      Style="{StaticResource RememberCheckboxStyle}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,18"
                      TabIndex="2"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="CancelButton"
                        Content="CANCEL"
                        Style="{StaticResource DialogButtonStyle}"
                        Click="CancelButton_Click"
                        MinWidth="100"
                        Margin="0,0,15,0"
                        TabIndex="3"/>
                <Button x:Name="ConfirmButton"
                        Content="OK"
                        Style="{StaticResource DialogButtonStyle}"
                        Click="ConfirmButton_Click"
                        MinWidth="100"
                        TabIndex="4"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
