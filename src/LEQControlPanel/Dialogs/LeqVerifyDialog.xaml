<Window x:Class="LEQControlPanel.Dialogs.LeqVerifyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verify LEQ Installation"
        Width="600"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource DialogOpacityButtonStyle}"/>
    </Window.Resources>

    <Border Background="{StaticResource Brush_BackgroundDark}"
            BorderBrush="{StaticResource Brush_BorderDark}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource Brush_TitleBar}" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x2705;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="Verify LEQ Installation"
                               FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush_TextWhite}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,15,20,10">

                <!-- Intro text -->
                <TextBlock Text="LEQ has been installed. Windows Sound Panel is now open."
                           Foreground="{StaticResource Brush_ForegroundMuted}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"/>

                <!-- Steps card -->
                <Border Background="{StaticResource Brush_PanelBg}" BorderBrush="#444444" BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="How to verify:" Foreground="#AAAAAA" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8" TextDecorations=""/>
                        <TextBlock Foreground="#DDDDDD" FontSize="13" LineHeight="22" TextWrapping="Wrap">
                            <Run Text="1."/><Run Text="  Right-click your device "/><Run Text="&#x2192;" Foreground="{StaticResource Brush_TitleGrey}"/><Run Text=" Properties"/>
                            <LineBreak/>
                            <Run Text="2."/><Run Text="  Go to the "/><Run Text="Enhancements" FontWeight="SemiBold"/><Run Text=" tab"/>
                            <LineBreak/>
                            <Run Text="3."/><Run Text="  Ensure "/><Run Text="Loudness Equalization" FontWeight="SemiBold"/><Run Text=" is checked"/>
                            <LineBreak/>
                            <Run Text="4."/><Run Text="  Click the "/><Run Text="Test" FontWeight="SemiBold"/><Run Text=" button"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Working / Not Working indicators -->
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Working -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,6">
                        <Run Text="&#x2713; WORKING" Foreground="#40C77F" FontWeight="Bold" FontSize="13"/>
                    </TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Test bars go full green repeatedly (LOUD)"
                               Foreground="{StaticResource Brush_ForegroundMuted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,0,6"/>

                    <!-- Not Working -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                        <Run Text="&#x2715; NOT WORKING" Foreground="#D94444" FontWeight="Bold" FontSize="13"/>
                    </TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Bars only touch the top briefly"
                               Foreground="{StaticResource Brush_ForegroundMuted}" FontSize="13" VerticalAlignment="Center"/>
                </Grid>

                <!-- Spatial Audio Warning -->
                <Border Background="{StaticResource Brush_PanelBg}" BorderThickness="2,1,1,1" CornerRadius="4" Padding="14" Margin="0,0,0,14">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E8A317" Offset="0"/>
                            <GradientStop Color="#E8A317" Offset="0.01"/>
                            <GradientStop Color="#333333" Offset="0.01"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="&#x26A0;&#xFE0F;" FontSize="13"/>
                            <Run Text=" Spatial Audio" Foreground="#E8A317" FontWeight="Bold" FontSize="13"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Brush_ForegroundMuted}" FontSize="13" LineHeight="20" TextWrapping="Wrap">
                            <Run Text="If Spatial Audio is enabled on this device (Windows Sonic, Dolby Atmos, DTS:X),"/>
                            <Run Text=" LEQ will not work." FontWeight="SemiBold"/>
                            <Run Text=" Disable it in:"/>
                            <LineBreak/>
                            <Run Text="Settings &#x2192; Sound &#x2192; your device &#x2192; Spatial Audio" Foreground="#AAAAAA" FontStyle="Italic"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Question -->
                <TextBlock Text="Did the test bars go full green repeatedly?"
                           Foreground="{StaticResource Brush_TextWhite}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="2" Margin="20,6,20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="NoButton"
                        Grid.Column="0"
                        Content="No"
                        Click="NoButton_Click"
                        TabIndex="0"
                        Height="36"
                        Margin="0,0,5,0"
                        Background="{StaticResource Brush_BorderDark}"
                        Foreground="{StaticResource Brush_ForegroundMuted}"
                        BorderBrush="{StaticResource Brush_BorderMedium}"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>

                <Button x:Name="YesButton"
                        Grid.Column="1"
                        Content="Yes"
                        Click="YesButton_Click"
                        TabIndex="1"
                        Height="36"
                        Margin="5,0,0,0"
                        Background="{StaticResource Brush_Accent}"
                        Foreground="{StaticResource Brush_BackgroundDark}"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
